# OpenAI / OpenAI-compatible providers, including OmniRoute.
LLM_PROVIDER=openai
LLM_MODEL=kr/claude-sonnet-4.5
OPENAI_API_KEY=sk-your-openai-or-omniroute-key
OPENAI_BASE_URL=http://localhost:20128/v1

# Anthropic:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-your-key

# OmniRouter:
# LLM_PROVIDER=openai
# LLM_MODEL=kr/claude-sonnet-4.5
# OPENAI_API_KEY=sk-your-omnirouter-key
# OPENAI_BASE_URL=https://api.omnirouter.ai/v1

# Ollama:
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434
